# Database
DATABASE_URL=postgresql://jarvis:jarvispass@localhost:5436/jarvis

# Redis
REDIS_URL=redis://localhost:6380

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9100
MINIO_ACCESS_KEY=jarvisadmin
MINIO_SECRET_KEY=jarvispassword
MINIO_BUCKET=jarvis-files

# Auth (SSO - replace with real values)
# 운영: 회사 IdP URL 직접 입력 (Okta, Azure AD, Entra 등)
# 로컬 개발: dev 계정 로그인 사용 — OIDC 불필요 (login 화면에서 임시 계정으로 로그인)
OIDC_ISSUER=https://auth.example.com/realms/your-org
OIDC_CLIENT_ID=jarvis-web
OIDC_CLIENT_SECRET=change-me-in-prod
NEXTAUTH_URL=http://localhost:3010
NEXTAUTH_SECRET=dev-secret-change-in-prod-32chars!!

# App
NEXT_PUBLIC_APP_NAME=Jarvis
NEXT_PUBLIC_APP_URL=http://localhost:3010

# LLM
# OpenAI 단일 제공자 — 임베딩(text-embedding-3-small) + 생성(gpt-5.4-mini) 통합
OPENAI_API_KEY=sk-...
# Ask AI 생성 모델 (기본값: gpt-5.4-mini)
ASK_AI_MODEL=gpt-5.4-mini

# Session
SESSION_SECRET=dev-session-secret-32-chars-min!!

# SOPS (secret management)
# SOPS_AGE_KEY_FILE=~/.sops/jarvis-age.key

# Graphify (code analysis pipeline)
# Graphify 바이너리는 100% 결정론적 (tree-sitter AST + NetworkX + Leiden/Louvain).
# 내부 LLM 호출 없음 — API 키 불필요. 의미 기반 보강은 @jarvis/ai 경유로 별도 수행.
# Path to graphify binary or 'graphify' if on PATH
GRAPHIFY_BIN=graphify
# Timeout for graphify subprocess in milliseconds
GRAPHIFY_TIMEOUT_MS=300000
# Max files in uploaded archive before rejection
GRAPHIFY_MAX_FILE_COUNT=500
# Max archive size in MB before rejection
GRAPHIFY_MAX_ARCHIVE_MB=100
# Auto-trigger graphify build when ZIP archive is uploaded
GRAPHIFY_AUTO_BUILD=false
