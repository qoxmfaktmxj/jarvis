# Database
DATABASE_URL=postgresql://jarvis:jarvispass@localhost:5436/jarvis

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9100
MINIO_ACCESS_KEY=jarvisadmin
MINIO_SECRET_KEY=jarvispassword
MINIO_BUCKET=jarvis-files

# Auth
# 이메일+비밀번호 인증 (개발: dev-accounts, 운영: 추후 bcrypt)

# App
NEXT_PUBLIC_APP_NAME=Jarvis
NEXT_PUBLIC_APP_URL=http://localhost:3010

# Wiki root resolution (Phase-W2+)
# SSoT 는 디스크의 wiki/ 디렉토리. 두 resolver 가 공존:
#   - apps/web: WIKI_REPO_ROOT (repo root) + "wiki" 접미
#   - packages/wiki-fs: WIKI_ROOT (직접 지정) 또는 WIKI_REPO_ROOT fallback
# 로컬·단일 머신이면 WIKI_REPO_ROOT 만 설정하면 둘 다 동일하게 해석됨.
WIKI_REPO_ROOT=/absolute/path/to/jarvis
# (선택) WIKI_ROOT 를 직접 지정하려면 아래 주석 해제. 없으면 WIKI_REPO_ROOT/wiki.
# WIKI_ROOT=/absolute/path/to/jarvis/wiki

# LLM
# OpenAI 단일 제공자 — 임베딩(text-embedding-3-small) + 생성(gpt-5.4-mini) 통합
# WARM-STANDBY: even when subscription gateway is enabled below, this key
# remains the fallback path (circuit breaker, embeddings, batch ingest).
OPENAI_API_KEY=sk-...
# Ask AI 생성 모델 (기본값: gpt-5.4-mini)
ASK_AI_MODEL=gpt-5.4-mini

# --- LLM Subscription Gateway (Phase-W1.5, CLIProxyAPI) ---
# Default URL is the docker-compose internal DNS. For host-side `pnpm dev`,
# override to http://localhost:8317/v1 after running:
#   docker compose -f docker/docker-compose.yml -f docker/docker-compose.dev.yml \
#     --profile gateway up -d cli-proxy
LLM_GATEWAY_URL=http://localhost:8317/v1
LLM_GATEWAY_KEY=sk-jarvis-local-dev

# Operation-level routing flags. Default OFF → packages/ai uses
# OPENAI_API_KEY direct. Flip individual operations on once the gateway has
# OAuth credentials loaded under infra/cliproxy/auths/. Ingest stays direct
# in pilot (ToS — automated/programmatic batch).
FEATURE_SUBSCRIPTION_INGEST=false
FEATURE_SUBSCRIPTION_QUERY=false
FEATURE_SUBSCRIPTION_LINT=false

# Session
SESSION_SECRET=dev-session-secret-32-chars-min!!

# SOPS (secret management)
# SOPS_AGE_KEY_FILE=~/.sops/jarvis-age.key

# Feature flags (Phase-W2 / W3)

# Phase-W2 T1: Two-Step CoT ingest (analysis LLM → generation LLM → commit).
# W2 완료 후 안정화됨. false로 두면 ingest가 knowledge_page/claim을 생성하지 않음.
FEATURE_TWO_STEP_INGEST=true

# Phase-W3 T4: wiki-fs 모드 (Karpathy-first). true=wiki_page_index 경로 활성화.
# true면 ingest가 disk + git 기반 wiki-fs 레이어에 쓰고, wiki_page_index가
# 1차 projection DB가 됨. false면 legacy knowledge_page 경로.
FEATURE_WIKI_FS_MODE=true

# true(기본). false면 legacy hybrid retrieval (knowledge_page/knowledge_claim).
FEATURE_PAGE_FIRST_QUERY=true

# Phase-γ LLM-first retrieval. false면 legacy SQL shortlist 사용.
FEATURE_LLM_SHORTLIST=false

# Phase-W2 T3: weekly wiki-lint cron (Sun 03:00 KST).
# true면 worker가 `wiki-lint-weekly` 스케줄 등록. false면 cron 미등록.
FEATURE_WIKI_LINT_CRON=true

# Graphify (code analysis pipeline)
# Graphify 바이너리는 100% 결정론적 (tree-sitter AST + NetworkX + Leiden/Louvain).
# 내부 LLM 호출 없음 — API 키 불필요. 의미 기반 보강은 @jarvis/ai 경유로 별도 수행.
# Path to graphify binary or 'graphify' if on PATH
GRAPHIFY_BIN=graphify
# Timeout for graphify subprocess in milliseconds
GRAPHIFY_TIMEOUT_MS=600000
# Max files in uploaded archive before rejection
GRAPHIFY_MAX_FILE_COUNT=5000
# Max archive size in MB before rejection
GRAPHIFY_MAX_ARCHIVE_MB=200
# Auto-trigger graphify build when ZIP archive is uploaded
GRAPHIFY_AUTO_BUILD=false
# Graphify wiki/auto/derived/code/** 격리 페이지 생성 (Phase-W3 v4-W3-T2).
# true면 worker가 Graphify 출력을 파일시스템 wiki tree(wiki/auto/derived/code/**)
# 로도 미러링. false(기본)면 DB(knowledge_page)에만 import. 현재 graphify-build.ts
# 는 DB 경로만 구현되어 있고, 이 flag는 미래 파일시스템 이관용 예약 스위치.
FEATURE_GRAPHIFY_DERIVED_PAGES=false
