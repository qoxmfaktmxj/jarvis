!docker/.env

# Turbo
.turbo/

# Drizzle
drizzle/
!packages/db/drizzle/
!packages/db/drizzle/**

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# API keys and secrets (never commit these)
*_key.txt
*_api_key
*_api_key.*
*.pem
*.p8
*.p12
*.pfx
secrets/
.gstack/

# Generated data — contains internal company data, regenerated from scripts
data/cases/*
!data/cases/README.md
data/canonical/*
!data/canonical/.gitkeep
data/directory/*
!data/directory/.gitkeep
data/guidebook/*
!data/guidebook/.gitkeep

# Git worktrees (Claude Code managed)
.claude/worktrees/

# Claude Code local state (per-machine, not shared)
.claude/*.local.md
.claude/*.lock

# Codex artifacts (screen captures, QA results)
.codex-artifacts/

# Playwright MCP cache
.playwright-mcp/

# Obsidian workspace
.obsidian/

# OMX / monitoring state
.omx/

# Jarvis agent workspace (planning files, not source)
_workspace/
_workspace_prev_*/

# Playwright test results
apps/web/test-results/

# IDE
jarvis.iml

# Python cache
scripts/__pycache__/
scripts/tests/__pycache__/

# Docs guidebook images (generated, large binaries)
docs/guidebook/images/

# Wiki build output (regenerated by ingest pipeline) — root-level only
/wiki/

# Infra export (TSMT001) — contains plaintext credentials, NEVER commit
TSMT001.sql
data/infra/
data/tsvd999.json

# Add-dev source xls (contains client project details) — local only
/추가개발/

# Misc local artifacts
/3.1_취업규칙.pdf

# Root-level ad-hoc captures and task archives
/*.png
/*.zip


# Superpowers brainstorm artifacts (local only)
.superpowers/
data/manual-ingest/*

# Local-only assets / dev data — drop files here that the AI can read
# but should never reach git (Excels, PDFs, sample data, scratch notes).
# Keep .gitkeep and README.md so the directory itself ships.
.local/*
!.local/.gitkeep
!.local/README.md

# Per-task handoff memos (not shared)
docs/handoff/

# Graphify pipeline output (regenerated)
graphify-out/
.graphify_uncached.txt
