# docker/.env — Docker Compose environment defaults (checked in)
#
# Docker Compose automatically reads this file when running `docker compose`
# from this directory (or when using `-f docker/docker-compose.yml`, the .env
# next to the compose file is picked up).
#
# COMPOSE_PROJECT_NAME fixes the Docker Desktop project group name so that
# containers/volumes/networks show up under "jarvis" regardless of which
# directory the compose command is invoked from. Without this, Compose falls
# back to the parent directory name (e.g. "docker") as the project name.
COMPOSE_PROJECT_NAME=jarvis
