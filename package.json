{
  "name": "jarvis",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "pnpm --filter=@jarvis/db generate",
    "db:migrate": "pnpm --filter=@jarvis/db migrate",
    "db:seed": "pnpm --filter=@jarvis/db seed",
    "db:studio": "pnpm --filter=@jarvis/db studio",
    "db:push": "pnpm --filter=@jarvis/db push",
    "eval:run": "tsx apps/worker/eval/run.ts",
    "test:integration": "pnpm --filter=@jarvis/worker test:integration",
    "wiki:check": "node scripts/wiki-check.mjs",
    "audit:rsc": "node scripts/audit-rsc-boundary.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.4.5",
    "openai": "^4.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild@0.18.20": "0.25.12",
      "@xmldom/xmldom": "^0.8.13"
    }
  },
  "dependencies": {
    "oracledb": "^6.10.0",
    "pg": "^8.20.0"
  }
}
