{
  "name": "@jarvis/auth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "default": "./dist/session.js"
    },
    "./rbac": {
      "types": "./dist/rbac.d.ts",
      "default": "./dist/rbac.js"
    },
    "./cookie": {
      "types": "./dist/cookie.d.ts",
      "default": "./dist/cookie.js"
    },
    "./return-url": {
      "types": "./dist/return-url.d.ts",
      "default": "./dist/return-url.js"
    },
    "./password": {
      "types": "./dist/password.d.ts",
      "default": "./dist/password.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "type-check": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@jarvis/db": "workspace:*",
    "@jarvis/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
