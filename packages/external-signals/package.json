{
  "name": "@jarvis/external-signals",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./exchangerate": {
      "types": "./dist/exchangerate.d.ts",
      "default": "./dist/exchangerate.js"
    },
    "./kma": {
      "types": "./dist/kma.d.ts",
      "default": "./dist/kma.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
