{
  "name": "@jarvis/wiki-fs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./writer": {
      "types": "./dist/writer.d.ts",
      "default": "./dist/writer.js"
    },
    "./frontmatter": {
      "types": "./dist/frontmatter.d.ts",
      "default": "./dist/frontmatter.js"
    },
    "./wikilink": {
      "types": "./dist/wikilink.d.ts",
      "default": "./dist/wikilink.js"
    },
    "./git": {
      "types": "./dist/git.d.ts",
      "default": "./dist/git.js"
    },
    "./worktree": {
      "types": "./dist/worktree.d.ts",
      "default": "./dist/worktree.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "simple-git": "^3.25.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
